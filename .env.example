# ═══════════════════════════════════════════════════════════════
# anchor-service — Environment Variables Template
# Copy this file to .env and fill in real values.
# ═══════════════════════════════════════════════════════════════

# ── Server ──
PORT=3003

# ── Anchor Platform (use Railway internal networking in production) ──
PLATFORM_API_URL=http://anchorplatform.railway.internal:8085

# ── Bank Simulator ──
BANK_URL=https://your-bank-sim.vercel.app

# ── Service-to-Service Auth ──
# ⚠️ Replace these with strong random secrets for production!
# Generate with: openssl rand -base64 32
ANCHOR_API_KEY=<strong-random-key>
BANK_API_KEY=<strong-random-key>

# ── Stellar ──
# ⚠️ ANCHOR_DISTRIBUTION_SECRET is REQUIRED — service will crash without it.
ANCHOR_DISTRIBUTION_SECRET=<your-distribution-secret-key>
NEXT_PUBLIC_USDC_ISSUER=<your-usdc-issuer-public-key>
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ╔══════════════════════════════════════════════════════════════╗
# ║ ⚠️  DO NOT set NODE_TLS_REJECT_UNAUTHORIZED=0 here!        ║
# ║ It disables TLS verification and is a MITM vulnerability.  ║
# ║ For local dev only, set it in your shell:                   ║
# ║   export NODE_TLS_REJECT_UNAUTHORIZED=0                     ║
# ╚══════════════════════════════════════════════════════════════╝
